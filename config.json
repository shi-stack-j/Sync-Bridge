{
  "configVersion": 1,

  "server": {
    "baseUrl": "https://arthritis-toys-tim-teaches.trycloudflare.com",
    "apiVersion": "v1"
  },

  "retry": {
    "connectionRetryAttempts": 2,
    "initialRetryIntervalMinutes": 10,
    "retryIntervalIncrementMinutes": 5,
    "maximumRetryIntervalMinutes": 60
  },

  "network": {
    "connectionTimeoutSeconds": 30,
    "readTimeoutSeconds": 30
  },

  "features": {
    "allowRegistration": true,
    "allowSync": true,
    "maintenanceMode": false
  }
}